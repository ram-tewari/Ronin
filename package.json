{
  "name": "ronin",
  "version": "1.0.0",
  "description": "Ronin - Desktop Pet Assistant",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"npm run vite\" \"wait-on http://localhost:51234 && electron .\"",
    "vite": "vite",
    "build": "vite build",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.0"
  },
  "build": {
    "appId": "com.ronin.desktop-pet",
    "productName": "Ronin",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
